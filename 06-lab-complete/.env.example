# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
MAX_TOOL_ROUNDS=3
MAX_TOOL_OUTPUT_CHARS=12000

# Research tools (optional)
# Tavily: https://app.tavily.com
TAVILY_API_KEY=
# Firecrawl: https://www.firecrawl.dev
FIRECRAWL_API_KEY=
ARXIV_USER_AGENT=Day12-Production-Agent/1.0 (your-email@example.com)

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0
INPUT_COST_PER_MILLION_USD=0.54
OUTPUT_COST_PER_MILLION_USD=4.50

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000
